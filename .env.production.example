# ==========================================
# KOVIL COMMUNITY - PRODUCTION ENV TEMPLATE
# ==========================================

# Core Application Target
NEXT_PUBLIC_APP_URL=https://kovilcommunity.com

# PostgreSQL Strict DSN
DATABASE_URL=postgresql://production_user:super_secret_password@db-host.supabase.co:5432/postgres

# JWT Encryption 
JWT_SECRET=your-secure-64-character-jwt-production-secret-here
JWT_EXPIRY=30d

# Payments (Phase 4)
STRIPE_SECRET_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXX

# Media Cloud Storage (Phase 4)
CLOUDINARY_CLOUD_NAME=your_cloud_tag
CLOUDINARY_UPLOAD_PRESET=kovil_secure_preset

# External API Integrations (Phase 5)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXX
